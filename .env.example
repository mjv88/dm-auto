# Database
DATABASE_URL=postgresql://runner:password@localhost:5432/runner_app

# Encryption (AES-256 for xAPI credential storage)
ENCRYPTION_KEY=

# Microsoft Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_RUNNERS_GROUP_ID=

# JWT Session Tokens
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Sentry
SENTRY_DSN=

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=3600000

# CORS — only requests from this origin are allowed (Runner PWA URL)
NEXT_PUBLIC_APP_URL=https://runner.example.com
